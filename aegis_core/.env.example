# Aegis Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── LLM Model ───────────────────────────────────────────────────────────────
# Any LiteLLM-compatible model string. Defaults to Gemini 1.5 Pro.
# Examples:
#   gemini/gemini-1.5-pro      (Google — free tier available)
#   gpt-4o                     (OpenAI)
#   anthropic/claude-opus-4-6 (Anthropic)
#   ollama/codellama           (local, no API key needed)
AEGIS_MODEL=gemini/gemini-1.5-pro

# ─── API Keys (set at least one) ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

GROQ_API_KEY=your_groq_api_key_here

# ─── GitHub Integration (optional, for webhook PR comments) ──────────────────
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
